{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MemDBG",
  "version": "2.0.0",
  "identifier": "dev.memdbg.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MemDBG",
        "width": 1600,
        "height": 1000,
        "minWidth": 1024,
        "minHeight": 720,

        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0B0D0F"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "PS4/PS5 memory debugger",
    "longDescription": "MemDBG is a memory debugger for PS4/PS5 consoles running the MemDBG payload."
  },
  "plugins": {}
}
